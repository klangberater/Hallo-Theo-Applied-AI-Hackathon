# Theo Copilot — environment variables
#
# Copy to /opt/fletcher/.env on the server (or .env locally for dev).
# NEVER commit the real .env.

# --- Postgres (fletcher-db on the server) -----------------------------------
DATABASE_URL=postgresql://fletcher:<password>@127.0.0.1:5433/fletcher
# search_path is set per-connection in code; theo schema is created via migration

# --- Neo4j (theo-neo4j container, from docker-compose.theo.yml) -------------
NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change-me-friday-night

# --- LLM keys ---------------------------------------------------------------
# Anthropic — agent loop (Opus for enrichment, Sonnet for intent classification)
ANTHROPIC_API_KEY=

# OpenAI — Graphiti's default fact-extraction LLM. WITHOUT this, the L3
# temporal memory silently degrades. Confirm key is funded before kickoff.
OPENAI_API_KEY=

# --- Model identifiers (override if Anthropic renames them) ----------------
# Confirm against docs.claude.com Friday morning — spec names may be stale.
ANTHROPIC_MODEL_REASONING=claude-opus-4-7
ANTHROPIC_MODEL_FAST=claude-sonnet-4-6

# --- Service ports (all 127.0.0.1) ------------------------------------------
THEO_INTAKE_PORT=8002
THEO_APP_PORT=8501

# --- WhatsApp bridge (Baileys) ---------------------------------------------
# Where the intake service POSTs outbound messages (auto-acknowledgements,
# approved replies). Leave at the default unless the bridge moves ports.
WHATSAPP_BRIDGE_URL=http://127.0.0.1:8003

# --- Feature flags ----------------------------------------------------------
# Kill-switch (§12.1): when false, l3_memory reads from a pre-computed JSON
# cache instead of querying Graphiti. Flip to false if Graphiti misbehaves
# Saturday afternoon.
USE_LIVE_GRAPHITI=true
KILL_SWITCH_CACHE_PATH=theo-copilot/scripts/_kill_switch_cache.json

# --- Dev convenience --------------------------------------------------------
LOG_LEVEL=INFO
